# Required: API key passed into the sandbox container so claude can authenticate.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: trials per (fixture × variant) pair. Default 3.
# Total trials = fixtures × 2 × TRIALS_PER_PAIR. With 5 fixtures and 3 reps
# that's 30 trials per run. Bump for tighter variance estimates.
TRIALS_PER_PAIR=3

# Optional: comma-separated fixture name substrings to filter to. Useful for
# debugging one trap. E.g. FIXTURE=01-wrong-diagnosis runs only that fixture.
# FIXTURE=

# Optional: override the headless claude invocation if your installed version
# uses different flags. The runner pipes the task prompt to stdin.
CLAUDE_COMMAND=claude -p --dangerously-skip-permissions --output-format text

# Optional: model used by the LLM-as-judge scorer. Default: claude-sonnet-4-6.
# Override to claude-opus-4-7 if you want stricter judgment at higher cost.
JUDGE_MODEL=claude-sonnet-4-6
